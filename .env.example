# PDIA Environment Variables

# Admin Dashboard Password (direct comparison or hash)
ADMIN_PASSWORD=admin123

# JWT Secret for session signing
JWT_SECRET=pdia-secret-key-change-in-production

# Gemini API Key for AI features
GEMINI_API_KEY=your_gemini_api_key_here

# Secret for emergency unlock endpoint
EMERGENCY_UNLOCK_SECRET=pdia-emergency-2026

# Hashing salt for analytics
ANALYTICS_SALT=pdia-analytics-salt-2026

# Session timeout in milliseconds (default 30 minutes)
SESSION_TIMEOUT=1800000

# Node Environment
NODE_ENV=development
